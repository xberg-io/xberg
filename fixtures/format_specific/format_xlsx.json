{
	"id": "format_xlsx",
	"category": "format_specific",
	"description": "XLSX spreadsheet extraction using extract",
	"tags": [
		"format_specific",
		"xlsx",
		"text_extraction"
	],
	"call": "extract",
	"input": {
		"kind": "uri",
		"uri": "xlsx/stanley_cups.xlsx",
		"mime_type": "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet"
	},
	"assertions": [
		{
			"type": "not_error"
		}
	],
	"skip": {
		"languages": [
			"wasm"
		],
		"reason": "WASM cannot access filesystem; use bytes input with file content instead"
	}
}
