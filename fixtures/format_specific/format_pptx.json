{
	"id": "format_pptx",
	"category": "format_specific",
	"description": "PPTX presentation extraction using extract",
	"tags": ["format_specific", "pptx", "text_extraction"],
	"call": "extract",
	"input": {
		"mock_responses": [
			{
				"path": "/pptx/simple.pptx",
				"status_code": 200,
				"headers": {
					"content-type": "application/vnd.openxmlformats-officedocument.presentationml.presentation"
				},
				"body_file": "../test_documents/pptx/simple.pptx"
			}
		],
		"extract_input": {
			"kind": "uri",
			"uri": "$mock_url/pptx/simple.pptx",
			"mime_type": "application/vnd.openxmlformats-officedocument.presentationml.presentation"
		}
	},
	"assertions": [
		{
			"type": "not_error"
		}
	],
	"skip": {
		"languages": ["wasm"],
		"reason": "WASM cannot access filesystem; use bytes input with file content instead"
	}
}
