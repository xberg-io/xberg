{
	"id": "format_hwpx_standalone",
	"category": "format_specific",
	"description": "Standalone HWPX extraction using extract",
	"tags": ["format_specific", "hwpx", "text_extraction"],
	"call": "extract",
	"input": {
		"mock_responses": [
			{
				"path": "/hwpx/simple.hwpx",
				"status_code": 200,
				"headers": {
					"content-type": "application/haansofthwpx"
				},
				"body_file": "../test_documents/hwpx/simple.hwpx"
			}
		],
		"extract_input": {
			"kind": "uri",
			"uri": "$mock_url/hwpx/simple.hwpx",
			"mime_type": "application/haansofthwpx",
			"filename": "simple.hwpx"
		}
	},
	"assertions": [
		{
			"type": "not_error"
		},
		{
			"type": "min_length",
			"field": "results[0].content",
			"value": 20
		},
		{
			"type": "contains",
			"field": "results[0].content",
			"value": "Hello from HWPX"
		}
	]
}
