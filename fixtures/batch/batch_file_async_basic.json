{
	"id": "batch_file_async_basic",
	"category": "batch",
	"description": "Extract text from multiple files asynchronously",
	"tags": [
		"batch",
		"async",
		"concurrent",
		"multiple_files"
	],
	"call": "extract_batch",
	"input": {
		"inputs": [
			{
				"kind": "uri",
				"uri": "pdf/fake_memo.pdf"
			},
			{
				"kind": "uri",
				"uri": "text/fake_text.txt"
			}
		]
	},
	"assertions": [
		{
			"type": "not_error"
		}
	],
	"skip": {
		"languages": [
			"wasm"
		],
		"reason": "WASM cannot access filesystem; use bytes input with file content instead"
	}
}
