{
	"id": "code_shebang_detection",
	"category": "code",
	"description": "Test language detection from shebang line via bytes input",
	"tags": [
		"code",
		"shebang",
		"tree-sitter"
	],
	"call": "extract",
	"input": {
		"kind": "uri",
		"uri": "code/script.sh",
		"mime_type": "text/x-source-code"
	},
	"assertions": [
		{
			"type": "equals",
			"field": "results.0.mime_type",
			"value": "text/x-source-code"
		},
		{
			"type": "min_length",
			"field": "results.0.content",
			"value": 10
		},
		{
			"type": "contains_all",
			"field": "results.0.content",
			"values": [
				"build",
				"clean"
			]
		}
	],
	"skip": {
		"languages": [
			"java",
			"typescript",
			"python",
			"ruby",
			"php",
			"go",
			"csharp",
			"elixir",
			"r",
			"dart",
			"kotlin_android",
			"swift",
			"zig",
			"c",
			"wasm"
		],
		"reason": "Code metadata variant is excluded from all language bindings (tree-sitter-specific; not part of polyglot API)"
	}
}
