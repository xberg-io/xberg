{
	"id": "pdf_password_protected",
	"category": "pdf",
	"description": "Copy-protected PDF should extract content (pdfium handles copy-protection transparently).",
	"document": {
		"path": "pdf/copy_protected.pdf",
		"media_type": "application/pdf"
	},
	"extraction": {
		"config": {}
	},
	"assertions": {
		"expected_mime": "application/pdf",
		"min_content_length": 50,
		"content_contains_any": ["LayoutParser", "document image analysis", "deep learning"]
	},
	"skip": {
		"if_document_missing": true
	}
}
