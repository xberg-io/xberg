{
	"id": "pdf_tables_small",
	"category": "pdf",
	"description": "Small PDF containing tables to validate table extraction.",
	"document": {
		"path": "pdf/tiny.pdf",
		"media_type": "application/pdf"
	},
	"extraction": {
		"config": {
			"output_format": "markdown",
			"layout": {
				"table_model": "tatr"
			}
		}
	},
	"assertions": {
		"expected_mime": "application/pdf",
		"min_content_length": 50,
		"content_contains_all": ["Table 1", "Selected Numbers", "Water Freezing Point", "Water Boiling Point"],
		"tables": {
			"min": 1
		}
	},
	"skip": {
		"requires_feature": ["ocr"],
		"skip_on_platform": ["aarch64-unknown-linux-gnu"],
		"notes": "PDF table extraction requires OCR feature. ONNX Runtime model loading unstable on ARM Linux."
	}
}
