{
	"id": "config_pages",
	"description": "Tests page extraction and page marker configuration",
	"tags": [
		"contract",
		"config"
	],
	"call": "extract",
	"input": {
		"kind": "uri",
		"uri": "pdf/fake_memo.pdf"
	},
	"assertions": [
		{
			"type": "equals",
			"field": "results.0.mime_type",
			"value": "application/pdf"
		},
		{
			"type": "min_length",
			"field": "results.0.content",
			"value": 10
		},
		{
			"type": "contains_any",
			"field": "results.0.content",
			"values": [
				"PAGE"
			]
		}
	],
	"skip": {
		"languages": [
			"wasm"
		],
		"reason": "WASM cannot access filesystem; use bytes input with file content instead"
	},
	"config": {
		"pages": {
			"extract_pages": true,
			"insert_page_markers": true
		}
	}
}
