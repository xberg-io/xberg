{
	"id": "config_tree_sitter",
	"description": "Tests tree-sitter configuration round-trip",
	"tags": [
		"contract",
		"config",
		"tree-sitter"
	],
	"call": "extract",
	"input": {
		"mock_responses": [
			{
				"path": "/code/hello.py",
				"status_code": 200,
				"headers": {
					"content-type": "application/octet-stream"
				},
				"body_file": "../test_documents/code/hello.py"
			}
		],
		"extract_input": {
			"kind": "uri",
			"uri": "$mock_url/code/hello.py"
		}
	},
	"assertions": [
		{
			"type": "equals",
			"field": "results[0].mime_type",
			"value": "text/x-source-code"
		},
		{
			"type": "min_length",
			"field": "results[0].content",
			"value": 5
		}
	],
	"skip": {
		"languages": [
			"wasm"
		],
		"reason": "WASM cannot access filesystem; use bytes input with file content instead"
	},
	"config": {
		"tree_sitter": {
			"languages": [
				"python",
				"rust"
			],
			"groups": [
				"web"
			],
			"process": {
				"structure": true,
				"imports": true,
				"exports": true,
				"comments": false,
				"docstrings": false,
				"symbols": false,
				"diagnostics": false
			}
		}
	}
}