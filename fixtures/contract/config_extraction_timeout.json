{
	"id": "config_extraction_timeout",
	"description": "Tests that extraction_timeout_secs config field is accepted and does not affect fast extractions",
	"tags": [
		"contract",
		"config",
		"timeout"
	],
	"call": "extract",
	"input": {
		"mock_responses": [
			{
				"path": "/pdf/fake_memo.pdf",
				"status_code": 200,
				"headers": {
					"content-type": "application/octet-stream"
				},
				"body_file": "../test_documents/pdf/fake_memo.pdf"
			}
		],
		"extract_input": {
			"kind": "uri",
			"uri": "$mock_url/pdf/fake_memo.pdf"
		}
	},
	"assertions": [
		{
			"type": "equals",
			"field": "results[0].mime_type",
			"value": "application/pdf"
		},
		{
			"type": "min_length",
			"field": "results[0].content",
			"value": 10
		}
	],
	"skip": {
		"languages": [
			"wasm"
		],
		"reason": "WASM cannot access filesystem; use bytes input with file content instead"
	},
	"config": {
		"extraction_timeout_secs": 300
	}
}