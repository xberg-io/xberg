{
	"id": "output_format_markdown",
	"description": "Tests Markdown output format",
	"tags": [
		"contract",
		"output_format"
	],
	"call": "extract",
	"input": {
		"kind": "uri",
		"uri": "pdf/fake_memo.pdf"
	},
	"assertions": [
		{
			"type": "equals",
			"field": "results.0.mime_type",
			"value": "application/pdf"
		},
		{
			"type": "min_length",
			"field": "results.0.content",
			"value": 10
		},
		{
			"type": "equals",
			"field": "results.0.metadata.output_format",
			"value": "markdown"
		}
	],
	"skip": {
		"languages": [
			"wasm"
		],
		"reason": "WASM cannot access filesystem; use bytes input with file content instead"
	},
	"config": {
		"output_format": "markdown"
	}
}
