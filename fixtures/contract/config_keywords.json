{
	"id": "config_keywords",
	"description": "Tests keyword extraction via YAKE algorithm",
	"tags": [
		"contract",
		"config",
		"keywords"
	],
	"call": "extract",
	"assertion_recipes": [
		"keywords"
	],
	"input": {
		"kind": "uri",
		"uri": "pdf/fake_memo.pdf"
	},
	"assertions": [
		{
			"type": "equals",
			"field": "results.0.mime_type",
			"value": "application/pdf"
		},
		{
			"type": "min_length",
			"field": "results.0.content",
			"value": 10
		},
		{
			"type": "not_empty",
			"field": "results.0.keywords"
		},
		{
			"type": "count_min",
			"field": "results.0.keywords",
			"value": 1
		}
	],
	"skip": {
		"languages": [
			"wasm"
		],
		"reason": "WASM cannot access filesystem; use bytes input with file content instead"
	},
	"config": {
		"keywords": {
			"algorithm": "yake",
			"max_keywords": 10
		}
	}
}
