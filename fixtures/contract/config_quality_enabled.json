{
	"id": "config_quality_enabled",
	"description": "Tests quality scoring produces a score value in [0.0, 1.0]",
	"tags": [
		"contract",
		"config",
		"quality"
	],
	"call": "extract",
	"input": {
		"kind": "uri",
		"uri": "pdf/fake_memo.pdf"
	},
	"assertions": [
		{
			"type": "equals",
			"field": "results.0.mime_type",
			"value": "application/pdf"
		},
		{
			"type": "min_length",
			"field": "results.0.content",
			"value": 10
		},
		{
			"type": "not_empty",
			"field": "quality_score"
		},
		{
			"type": "greater_than_or_equal",
			"field": "quality_score",
			"value": 0.0
		},
		{
			"type": "less_than_or_equal",
			"field": "quality_score",
			"value": 1.0
		}
	],
	"skip": {
		"languages": [
			"wasm"
		],
		"reason": "WASM cannot access filesystem; use bytes input with file content instead"
	},
	"config": {
		"enable_quality_processing": true
	}
}
