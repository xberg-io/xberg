{
	"id": "config_force_ocr_pages",
	"description": "Tests that force_ocr_pages config field is accepted for selective page OCR",
	"tags": ["contract", "config", "ocr"],
	"document": {
		"path": "pdf/fake_memo.pdf"
	},
	"extraction": {
		"method": "sync",
		"input_type": "file",
		"config": {
			"force_ocr_pages": [1],
			"ocr": {
				"backend": "tesseract",
				"language": "eng"
			}
		}
	},
	"assertions": {
		"expected_mime": "application/pdf",
		"min_content_length": 1
	},
	"skip": {
		"requires_feature": ["ocr"]
	}
}
