{
	"id": "api_extract_batch_uri_async",
	"description": "Tests async batch file extraction API (extract_batch)",
	"tags": [
		"contract",
		"api",
		"batch"
	],
	"call": "extract_batch",
	"input": {
		"inputs": [
			{
				"kind": "uri",
				"uri": "pdf/fake_memo.pdf"
			}
		]
	},
	"assertions": [
		{
			"type": "equals",
			"field": "results.0.mime_type",
			"value": "application/pdf"
		},
		{
			"type": "min_length",
			"field": "results.0.content",
			"value": 10
		},
		{
			"type": "contains_any",
			"field": "results.0.content",
			"values": [
				"May 5, 2023",
				"Mallori"
			]
		}
	],
	"skip": {
		"languages": [
			"wasm"
		],
		"reason": "WASM uses synchronous-only API; async extraction is not available on the wasm target"
	}
}
