{
	"id": "ocr_paddle_table_detection",
	"category": "ocr",
	"description": "Table detection and extraction with PaddleOCR.",
	"document": {
		"path": "images/simple_table.png",
		"media_type": "image/png",
		"requires_external_tool": ["paddle-ocr", "onnxruntime"]
	},
	"extraction": {
		"config": {
			"output_format": "markdown",
			"ocr": {
				"backend": "paddle-ocr",
				"language": "en",
				"paddle_ocr_config": {
					"enable_table_detection": true
				}
			},
			"force_ocr": true
		}
	},
	"assertions": {
		"expected_mime": "image/png",
		"min_content_length": 10,
		"content_contains_any": ["Product", "Apple", "Banana", "Orange"]
	},
	"skip": {
		"requires_feature": ["paddle-ocr"],
		"skip_on_platform": ["aarch64-unknown-linux-gnu"],
		"notes": "Tests table detection capability with PaddleOCR. ONNX Runtime model loading unstable on ARM Linux."
	}
}
