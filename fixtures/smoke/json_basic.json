{
	"id": "smoke_json_basic",
	"category": "smoke",
	"description": "Smoke test: JSON file extraction",
	"tags": [
		"smoke",
		"structured",
		"json"
	],
	"input": {
		"mock_responses": [
			{
				"path": "/json/simple.json",
				"status_code": 200,
				"headers": {
					"content-type": "application/octet-stream"
				},
				"body_file": "../test_documents/json/simple.json"
			}
		],
		"extract_input": {
			"kind": "uri",
			"uri": "$mock_url/json/simple.json",
			"mime_type": "application/json"
		}
	},
	"assertions": [
		{
			"type": "equals",
			"field": "results[0].mime_type",
			"value": "application/json"
		},
		{
			"type": "min_length",
			"field": "results[0].content",
			"value": 5
		}
	],
	"skip": {
		"languages": [
			"wasm"
		],
		"reason": "WASM cannot access filesystem; use bytes input with file content instead"
	},
	"call": "extract",
	"config": {}
}