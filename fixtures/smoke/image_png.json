{
	"id": "smoke_image_png",
	"category": "smoke",
	"description": "Smoke test: PNG image (without OCR, metadata only)",
	"tags": [
		"smoke",
		"image",
		"png"
	],
	"input": {
		"kind": "uri",
		"uri": "images/sample.png"
	},
	"assertions": [
		{
			"type": "equals",
			"field": "results.0.mime_type",
			"value": "image/png"
		}
	],
	"skip": {
		"languages": [
			"wasm"
		],
		"reason": "WASM cannot access filesystem; use bytes input with file content instead"
	},
	"call": "extract",
	"config": {
		"disable_ocr": true
	}
}
