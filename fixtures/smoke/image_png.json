{
	"id": "smoke_image_png",
	"category": "smoke",
	"description": "Smoke test: PNG image (without OCR, metadata only)",
	"tags": [
		"smoke",
		"image",
		"png"
	],
	"input": {
		"mock_responses": [
			{
				"path": "/images/sample.png",
				"status_code": 200,
				"headers": {
					"content-type": "application/octet-stream"
				},
				"body_file": "../test_documents/images/sample.png"
			}
		],
		"extract_input": {
			"kind": "uri",
			"uri": "$mock_url/images/sample.png"
		}
	},
	"assertions": [
		{
			"type": "equals",
			"field": "results[0].mime_type",
			"value": "image/png"
		}
	],
	"skip": {
		"languages": [
			"wasm"
		],
		"reason": "WASM cannot access filesystem; use bytes input with file content instead"
	},
	"call": "extract",
	"config": {
		"disable_ocr": true
	}
}