{
	"id": "smoke_xlsx_basic",
	"category": "smoke",
	"description": "Smoke test: XLSX with basic spreadsheet data including tables",
	"tags": [
		"smoke",
		"office",
		"xlsx",
		"tables"
	],
	"input": {
		"kind": "uri",
		"uri": "xlsx/stanley_cups.xlsx",
		"mime_type": "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet"
	},
	"assertions": [
		{
			"type": "equals",
			"field": "results.0.mime_type",
			"value": "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet"
		},
		{
			"type": "min_length",
			"field": "results.0.content",
			"value": 100
		},
		{
			"type": "contains_all",
			"field": "results.0.content",
			"values": [
				"Team",
				"Location",
				"Stanley Cups",
				"Blues",
				"Flyers",
				"Maple Leafs",
				"STL",
				"PHI",
				"TOR"
			]
		},
		{
			"type": "count_min",
			"field": "results.0.tables",
			"value": 1
		},
		{
			"type": "greater_than_or_equal",
			"field": "results.0.metadata.format.excel.sheet_count",
			"value": 2
		},
		{
			"type": "contains_all",
			"field": "results.0.metadata.format.excel.sheet_names",
			"values": [
				"Stanley Cups"
			]
		}
	],
	"skip": {
		"languages": [
			"wasm"
		],
		"reason": "WASM cannot access filesystem; use bytes input with file content instead"
	},
	"call": "extract",
	"config": {}
}
