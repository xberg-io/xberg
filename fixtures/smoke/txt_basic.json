{
	"id": "smoke_txt_basic",
	"category": "smoke",
	"description": "Smoke test: Plain text file",
	"tags": [
		"smoke",
		"text",
		"plaintext"
	],
	"input": {
		"kind": "uri",
		"uri": "text/report.txt",
		"mime_type": "text/plain"
	},
	"assertions": [
		{
			"type": "equals",
			"field": "results.0.mime_type",
			"value": "text/plain"
		},
		{
			"type": "min_length",
			"field": "results.0.content",
			"value": 5
		}
	],
	"skip": {
		"languages": [
			"wasm"
		],
		"reason": "WASM cannot access filesystem; use bytes input with file content instead"
	},
	"call": "extract",
	"config": {}
}
