{
  "name": "@xberg-io/llamaindex-xberg",
  "version": "1.0.0-rc.32",
  "description": "LlamaIndex.TS reader and node parser for Xberg — extract text, tables, metadata, and structure-aware nodes from 90+ document formats with optional OCR.",
  "keywords": [
    "llamaindex",
    "llama-index",
    "xberg",
    "document-extraction",
    "rag",
    "reader",
    "node-parser",
    "ocr",
    "pdf",
    "text-extraction"
  ],
  "license": "MIT",
  "homepage": "https://github.com/xberg-io/xberg/tree/main/integrations/node/llamaindex-xberg",
  "author": {
    "name": "Xberg.dev",
    "email": "contact@xberg.io"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xberg-io/xberg.git",
    "directory": "integrations/node/llamaindex-xberg"
  },
  "engines": {
    "node": ">=20.15"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vitest run"
  },
  "dependencies": {
    "@xberg-io/xberg": "1.0.0-rc.32"
  },
  "peerDependencies": {
    "@llamaindex/core": "^0.6.0"
  },
  "devDependencies": {
    "@llamaindex/core": "^0.6.22",
    "@types/node": "^20.19.0",
    "@typescript-eslint/eslint-plugin": "^8.20.0",
    "@typescript-eslint/parser": "^8.20.0",
    "eslint": "^8.57.0",
    "tsup": "^8.3.5",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  },
  "publishConfig": {
    "access": "public"
  }
}
