{
	"compilerOptions": {
		"ignoreDeprecations": "6.0",
		"target": "ES2020",
		"module": "ESNext",
		"lib": ["ES2020"],
		"moduleResolution": "node",
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true,
		"resolveJsonModule": true,
		"declaration": true,
		"declarationMap": true,
		"sourceMap": true,
		"outDir": "./dist",
		"rootDir": "."
	},
	"include": ["tests/**/*.ts", "vitest.config.ts"],
	"exclude": ["node_modules", "dist"]
}
