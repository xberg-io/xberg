import gleeunit
import gleeunit/should
import kreuzberg

import gleam/list
import gleam/string

// Tests chunking without embeddings - chunks should not have embedding vectors
pub fn embedding_disabled_test() {
  let result = kreuzberg.extract_file_sync("pdf/fake_memo.pdf", "{\"chunking\":{\"max_chars\":500,\"max_overlap\":50}}")
  result |> should.be_ok()
  result.mime_type |> should.equal("application/pdf")
  result.content |> string.length |> int.is_at_least(10) |> should.equal(True)
  result.chunks |> list.length |> int.is_at_least(1) |> should.equal(True)
  result.chunks_have_content |> should.equal(True)
}

