{
	"name": "@xberg-io/xberg-tsproject",
	"version": "1.0.0-rc.1",
	"private": true,
	"description": "High-performance document intelligence library",
	"keywords": [
		"document",
		"extraction",
		"ocr",
		"pdf",
		"text"
	],
	"homepage": "https://xberg.io",
	"license": "MIT",
	"author": "Na'aman Hirschfeld <naaman@xberg.io>",
	"repository": "https://github.com/xberg-io/xberg",
	"files": [
		"index.js",
		"index.d.ts",
		"**/*.node"
	],
	"main": "index.js",
	"types": "index.d.ts",
	"scripts": {
		"build": "napi build --release",
		"build:debug": "napi build",
		"build:ts": "echo 'No TypeScript wrapper to build'",
		"test": "node -e \"console.log('Add test command')\"",
		"format": "oxfmt",
		"format:check": "oxfmt --check",
		"lint": "oxlint",
		"lint:fix": "oxlint --fix"
	},
	"devDependencies": {
		"@napi-rs/cli": "^3.0.0",
		"oxfmt": "latest",
		"oxlint": "latest",
		"typescript": "^6.0.3"
	},
	"napi": {
		"name": "xberg",
		"triples": [
			"x86_64-unknown-linux-gnu",
			"x86_64-apple-darwin",
			"aarch64-apple-darwin",
			"x86_64-pc-windows-msvc"
		]
	}
}
