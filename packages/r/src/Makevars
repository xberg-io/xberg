CARGO_BUILD_ARGS = --release
STATLIB = ./rust/target/release/libxberg_r.a
PKG_LIBS = -L./rust/target/release -lxberg_r $(LAPACK_LIBS) $(BLAS_LIBS) $(FLIBS)

all: $(SHLIB)

$(STATLIB):
	cargo build --manifest-path ./rust/Cargo.toml $(CARGO_BUILD_ARGS)

$(SHLIB): $(STATLIB)

binary:
	cd .. && R CMD INSTALL --build .

clean:
	rm -f $(SHLIB) $(STATLIB)
	cargo clean --manifest-path ./rust/Cargo.toml
