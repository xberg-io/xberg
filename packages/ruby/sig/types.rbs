  interface _OcrBackend
    def process_image: (String image_bytes, OcrConfig config) -> ExtractionResult
    def process_image_file: (String path, OcrConfig config) -> ExtractionResult
    def supports_language: (String lang) -> bool
    def backend_type: () -> OcrBackendType
    def supported_languages: () -> Array[String]
    def supports_table_detection: () -> bool
    def supports_document_processing: () -> bool
    def emits_structured_markdown: () -> bool
    def process_document: (String _path, OcrConfig _config) -> ExtractionResult
  end

  interface _PostProcessor
    def process: (ExtractionResult result, ExtractionConfig config) -> void
    def processing_stage: () -> ProcessingStage
    def should_process: (ExtractionResult _result, ExtractionConfig _config) -> bool
    def estimated_duration_ms: (ExtractionResult _result) -> Integer
    def priority: () -> Integer
  end

  interface _Validator
    def validate: (ExtractionResult result, ExtractionConfig config) -> void
    def should_validate: (ExtractionResult _result, ExtractionConfig _config) -> bool
    def priority: () -> Integer
  end

  interface _EmbeddingBackend
    def dimensions: () -> Integer
    def embed: (Array[String] texts) -> Array[Array[Float]]
  end

  interface _Renderer
    def render: (InternalDocument doc) -> String
  end

  interface _RerankerBackend
    def rerank: (String query, Array[String] documents) -> Array[Float]
  end

