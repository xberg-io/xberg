{
  "name": "xberg-wasm-runtime",
  "version": "1.0.0-rc.1",
  "description": "Shared JavaScript/TypeScript runtime layer for xberg wasm engine (injected embedder, vector store, NER, OCR, model cache)",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "build": "npm run clean && tsc",
    "build:sqlite-wasm": "node scripts/build-sqlite-vec-wasm.mjs",
    "setup:models": "pnpm run build && node scripts/setup-models.mjs",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:browser": "playwright test",
    "test:models": "cross-env XBERG_RUN_MODEL_DOWNLOAD_TESTS=1 vitest run src/cache.test.ts --testNamePattern=downloads",
    "lint": "oxlint src/",
    "format": "oxfmt src/"
  },
  "dependencies": {
    "@huggingface/transformers": "^3.0.0",
    "better-sqlite3": "^12.11.1",
    "onnxruntime-web": "^1.18.0",
    "ppu-paddle-ocr": "^6.0.0",
    "sqlite-vec": "^0.1.9",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.0.0",
    "@vitest/coverage-v8": "^4.1.9",
    "cross-env": "^10.1.0",
    "oxfmt": "^0.58.0",
    "oxlint": "^1.73.0",
    "ppu-ocv": "3.3.0",
    "typescript": "^6.0.3",
    "vite": "^8.1.3",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3"
    ]
  }
}
