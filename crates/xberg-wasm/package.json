{
  "name": "@xberg-io/xberg-wasm",
  "version": "1.0.0-rc.35",
  "private": false,
  "description": "High-performance document intelligence library",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/xberg-io/xberg",
    "directory": "crates/xberg-wasm"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "files": ["pkg/web", "README.md"],
  "main": "pkg/web/xberg_wasm.js",
  "module": "pkg/web/xberg_wasm.js",
  "types": "pkg/web/xberg_wasm.d.ts",
  "engines": {
    "node": ">= 22"
  },
  "scripts": {
    "build": "wasm-pack build --target web --out-dir pkg/web",
    "build:ci": "wasm-pack build --release --target web --out-dir pkg/web",
    "build:wasm:web": "wasm-pack build --release --target web --out-dir pkg/web",
    "build:all": "npm run build:wasm:web && find pkg -name .gitignore -delete",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "test:coverage": "vitest run --coverage",
    "clean": "rm -rf pkg dist"
  }
}
