{
	"compilerOptions": {
		"target": "ES2022",
		"module": "NodeNext",
		"moduleResolution": "NodeNext",
		"lib": ["ES2022", "DOM", "DOM.Iterable", "WebWorker"],
		"types": ["node"],
		"outDir": "dist",
		"rootDir": "typescript",
		"declaration": true,
		"strict": true,
		"skipLibCheck": true,
		"isolatedModules": true,
		"noEmit": false
	},
	"include": ["typescript/**/*"],
	"exclude": ["node_modules", "dist", "pkg", "pkg-nodejs", "scripts", "typescript/**/*.spec.ts"]
}
